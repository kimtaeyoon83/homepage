    # }
}

myram.duckdns.org {
    log {
        output stdout
        format console
    }

    # API requests to myai-memory backend
    @myai_api path /api /api/*
    handle @myai_api {
        reverse_proxy http://myai-memory-backend-prod:4000
    }

    # Frontend for all other requests
    handle {
        reverse_proxy http://myai-memory-frontend-prod:3000
    }
}

