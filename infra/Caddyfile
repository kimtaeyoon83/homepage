    # handle @rainborn_static {
    #     uri replace /rainborn-static /toy/rainborn
    #     reverse_proxy http://rainborn-frontend:3000
    # }
    # @rainborn_frontend path /toy/rainborn /toy/rainborn/*
    # handle @rainborn_frontend {
    #     reverse_proxy http://rainborn-frontend:3000
    # }
    # @main_api path /api /api/*
